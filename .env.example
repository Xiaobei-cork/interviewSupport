# Database (docker-compose.dev.yml defaults)
DATABASE_URL=mysql+pymysql://interview:interview123@localhost:3306/interview_assistant?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT - change in production
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=10080

# DeepSeek - set key to enable live AI (resume/interview analyze, chat, deep-optimize)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Aliyun OSS - leave empty for local file storage fallback
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_CDN_DOMAIN=

# Optional: Aliyun ASR for real audio transcription
ALIYUN_ASR_APP_KEY=
ALIYUN_ASR_ACCESS_KEY_ID=
ALIYUN_ASR_ACCESS_KEY_SECRET=

# App
UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
